  "@type": "sc:Dataset",
  "name": "KV-Cache Inception Runtime Interventions (Batch)",
  "description": "Merged runtime evidence from multiple Reversible MCTS runs in KV-cache latent space. Each record is one MCTS node with telemetry channels, diagnostic classification, OEI/TDS metrics, and reproducibility provenance.",
